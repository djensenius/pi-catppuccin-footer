{
	"name": "pi-catppuccin-footer",
	"version": "0.1.2",
	"description": "A Catppuccin/tmux-style configurable footer extension for Pi.",
	"keywords": [
		"pi-package",
		"pi-extension",
		"catppuccin",
		"tmux",
		"footer",
		"statusline"
	],
	"license": "MIT",
	"type": "module",
	"files": [
		"assets",
		"extensions",
		"examples",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./extensions/catppuccin-footer.ts"
		],
		"image": "https://raw.githubusercontent.com/djensenius/pi-catppuccin-footer/main/assets/catppuccin-footer.png"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-ai": "^0.74.0",
		"@earendil-works/pi-coding-agent": "^0.74.0",
		"@earendil-works/pi-tui": "^0.74.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.2",
		"eslint": "^10.3.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.12",
		"vitest": "^4.1.6"
	},
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run pack:check",
		"ci": "npm run check",
		"pack:check": "npm pack --dry-run"
	}
}
